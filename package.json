{
  "name": "confluence-room-pilot",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src vite.config.ts",
    "perf": "node scripts/perf_harness.mjs",
    "evidence:room01": "node scripts/capture_room_evidence.mjs http://127.0.0.1:4173 1 /assets/room-01-kiosk.glb",
    "evidence:rooms02-12": "node scripts/capture_rooms_02_12.mjs http://127.0.0.1:4173",
    "audio:generate": "node scripts/generate_audio.mjs",
    "audio:generate:sfx": "node scripts/generate_audio.mjs --skip-music sfx",
    "validate:rooms": "node scripts/validate_rooms.mjs",
    "validate:rooms:strict": "node scripts/validate_rooms.mjs --strict",
    "assets:inventory": "node scripts/asset_inventory.mjs",
    "validate": "npm run typecheck && npm run lint && npm run validate:rooms"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "gsap": "^3.15.0",
    "postprocessing": "^6.39.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "puppeteer-core": "^25.3.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
