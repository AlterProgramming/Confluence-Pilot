{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://confluence-pilot.local/schemas/dimension-procedural-asset.schema.json",
  "title": "Dimension Procedural Source Asset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "realm",
    "category",
    "revision",
    "description",
    "narrativeFunction",
    "scale",
    "orientation",
    "silhouette",
    "materials",
    "components",
    "generation",
    "topology",
    "animation",
    "lod",
    "collision",
    "sockets",
    "orthographicGuidance",
    "validation"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 3 },
    "realm": { "enum": ["the-weight-of-remembering", "parallel-remembrance"] },
    "category": {
      "enum": [
        "celestial-mechanism",
        "structural-rib",
        "architectural-module",
        "city-tower",
        "energy-filament",
        "chain-assembly",
        "dimensional-lattice",
        "archive-megastructure",
        "bridge-span",
        "organic-growth",
        "monolith",
        "timeline-debris"
      ]
    },
    "revision": { "type": "integer", "minimum": 1 },
    "description": { "type": "string", "minLength": 160 },
    "narrativeFunction": { "type": "string", "minLength": 100 },
    "designKeywords": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "scale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "bounds", "heroScale", "modularScale"],
      "properties": {
        "unit": { "const": "meter" },
        "bounds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height", "depth"],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "depth": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "heroScale": { "type": "number", "exclusiveMinimum": 0 },
        "modularScale": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "orientation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upAxis", "forwardAxis", "pivot", "originMeaning"],
      "properties": {
        "upAxis": { "const": "+Y" },
        "forwardAxis": { "enum": ["+Z", "-Z"] },
        "pivot": {
          "type": "array",
          "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
          "items": false
        },
        "originMeaning": { "type": "string", "minLength": 20 }
      }
    },
    "silhouette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary", "tertiary", "negativeSpace", "recognitionTest"],
      "properties": {
        "primary": { "type": "string", "minLength": 80 },
        "secondary": { "type": "string", "minLength": 80 },
        "tertiary": { "type": "string", "minLength": 80 },
        "negativeSpace": { "type": "string", "minLength": 80 },
        "recognitionTest": { "type": "string", "minLength": 80 }
      }
    },
    "materials": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "baseColor", "metallic", "roughness", "emission", "surfaceDescription"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string" },
          "baseColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "metallic": { "type": "number", "minimum": 0, "maximum": 1 },
          "roughness": { "type": "number", "minimum": 0, "maximum": 1 },
          "emission": {
            "type": "object",
            "required": ["color", "strength"],
            "properties": {
              "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "strength": { "type": "number", "minimum": 0 }
            }
          },
          "surfaceDescription": { "type": "string", "minLength": 60 }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "primitive", "role", "dimensions", "transform", "material", "detail"],
        "properties": {
          "id": { "type": "string" },
          "primitive": {
            "enum": ["box", "cylinder", "sphere", "icosphere", "torus", "curve-tube", "plane", "cone", "custom-profile"]
          },
          "role": { "type": "string", "minLength": 20 },
          "dimensions": { "type": "object" },
          "transform": {
            "type": "object",
            "required": ["position", "rotation", "scale"],
            "properties": {
              "position": { "$ref": "#/$defs/vector3" },
              "rotation": { "$ref": "#/$defs/vector3" },
              "scale": { "$ref": "#/$defs/vector3" }
            }
          },
          "material": { "type": "string" },
          "detail": { "type": "string", "minLength": 60 },
          "repeat": {
            "type": "object",
            "additionalProperties": true,
            "required": ["mode", "count"],
            "properties": {
              "mode": { "enum": ["none", "radial", "linear", "grid", "arc", "strand", "scatter"] },
              "count": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "deterministic", "assemblyOrder", "deformationRules", "variationRules"],
      "properties": {
        "seed": { "type": "integer" },
        "deterministic": { "const": true },
        "assemblyOrder": { "type": "array", "minItems": 3, "items": { "type": "string" } },
        "deformationRules": { "type": "array", "items": { "type": "string", "minLength": 30 } },
        "variationRules": { "type": "array", "items": { "type": "string", "minLength": 30 } }
      }
    },
    "topology": {
      "type": "object",
      "required": ["target", "bevel", "subdivision", "normals", "uv", "watertightParts"],
      "properties": {
        "target": { "type": "string", "minLength": 40 },
        "bevel": { "type": "string", "minLength": 30 },
        "subdivision": { "type": "string", "minLength": 30 },
        "normals": { "type": "string", "minLength": 30 },
        "uv": { "type": "string", "minLength": 30 },
        "watertightParts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "animation": {
      "type": "object",
      "required": ["channels", "loopLengthSeconds", "motionCharacter", "constraints"],
      "properties": {
        "channels": { "type": "array", "items": { "type": "string" } },
        "loopLengthSeconds": { "type": "number", "minimum": 0 },
        "motionCharacter": { "type": "string", "minLength": 60 },
        "constraints": { "type": "array", "items": { "type": "string", "minLength": 30 } }
      }
    },
    "lod": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "screenCoverage", "triangleBudget", "preserve"],
        "properties": {
          "name": { "type": "string" },
          "screenCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "triangleBudget": { "type": "integer", "minimum": 12 },
          "preserve": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "collision": {
      "type": "object",
      "required": ["mode", "description"],
      "properties": {
        "mode": { "enum": ["none", "box", "capsule", "convex-hull", "compound", "custom"] },
        "description": { "type": "string", "minLength": 40 }
      }
    },
    "sockets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "purpose", "position", "rotation"],
        "properties": {
          "id": { "type": "string" },
          "purpose": { "type": "string" },
          "position": { "$ref": "#/$defs/vector3" },
          "rotation": { "$ref": "#/$defs/vector3" }
        }
      }
    },
    "orthographicGuidance": {
      "type": "object",
      "required": ["front", "side", "top", "threeQuarter", "scaleCue"],
      "properties": {
        "front": { "type": "string", "minLength": 70 },
        "side": { "type": "string", "minLength": 70 },
        "top": { "type": "string", "minLength": 70 },
        "threeQuarter": { "type": "string", "minLength": 70 },
        "scaleCue": { "type": "string", "minLength": 40 }
      }
    },
    "validation": {
      "type": "array",
      "minItems": 6,
      "items": { "type": "string", "minLength": 35 }
    }
  },
  "$defs": {
    "vector3": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
      "items": false
    }
  }
}
